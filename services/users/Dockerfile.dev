# Development Dockerfile for Users Service with hot reload
FROM cgr.dev/chainguard/rust:latest-dev as builder

WORKDIR /app

# Copy manifests
COPY Cargo.toml Cargo.lock ./

# Create dummy main to cache dependencies
RUN mkdir src && echo "fn main() {}" > src/main.rs

# Build dependencies
RUN cargo build && rm -rf src target/debug/deps/users*

# Copy source
COPY src ./src

# Build for development (debug mode for faster builds)
RUN cargo build

# Runtime stage
FROM cgr.dev/chainguard/rust:latest-dev

WORKDIR /app

# Copy built binary
COPY --from=builder /app/target/debug/users /usr/local/bin/users

# Set the user to non-root
USER 65532:65532

# Expose port
EXPOSE 8080

# Start application
CMD ["/usr/local/bin/users"]