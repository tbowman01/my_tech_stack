# Enterprise AI Platform - Environment Configuration
# Copy this file to .env and customize for your environment

# =============================================================================
# Application Configuration
# =============================================================================

# Environment
NODE_ENV=development
PYTHON_ENV=development
RUST_LOG=info
LOG_LEVEL=info

# Service Ports
API_GATEWAY_PORT=8080
USERS_SERVICE_PORT=8081
AI_INFERENCE_PORT=8082

# =============================================================================
# Database Configuration
# =============================================================================

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=enterprise_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_dev_password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# ClickHouse
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=analytics
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=clickhouse_dev_password

# Qdrant (Vector Database)
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_URL=http://qdrant:6333

# OpenSearch
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
OPENSEARCH_URL=http://opensearch:9200

# =============================================================================
# Observability Configuration
# =============================================================================

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_VERSION=0.1.0
OTEL_RESOURCE_ATTRIBUTES=environment=development

# Prometheus
PROMETHEUS_URL=http://prometheus:9090

# Grafana
GRAFANA_URL=http://grafana:3000
GRAFANA_ADMIN_PASSWORD=admin

# Jaeger
JAEGER_URL=http://jaeger:16686
JAEGER_COLLECTOR_URL=http://jaeger:14250

# Loki
LOKI_URL=http://loki:3100

# =============================================================================
# External Services
# =============================================================================

# OpenAI API (for AI services)
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic Claude API
# ANTHROPIC_API_KEY=your-anthropic-api-key

# Hugging Face
# HUGGINGFACE_API_KEY=your-huggingface-api-key

# =============================================================================
# Security Configuration
# =============================================================================

# JWT Configuration
# JWT_SECRET=your-jwt-secret-key-min-32-chars
# JWT_EXPIRES_IN=24h

# API Keys (for service-to-service communication)
# API_GATEWAY_API_KEY=dev-api-gateway-key
# USERS_SERVICE_API_KEY=dev-users-service-key
# AI_SERVICE_API_KEY=dev-ai-service-key

# =============================================================================
# Docker Configuration
# =============================================================================

# Container Registry
REGISTRY=ghcr.io
REGISTRY_ORG=your-org
IMAGE_TAG=latest

# Docker Compose Override
COMPOSE_FILE=docker-compose.yml:docker-compose.override.yml

# =============================================================================
# Development Configuration
# =============================================================================

# Hot Reload
CHOKIDAR_USEPOLLING=true
WATCHPACK_POLLING=true

# Debug
DEBUG=*
DEBUG_COLORS=true

# =============================================================================
# Monitoring and Alerting
# =============================================================================

# Slack (for alerts)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/slack/webhook

# Email (for notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# =============================================================================
# Feature Flags
# =============================================================================

# Enable/disable features
ENABLE_AI_FEATURES=true
ENABLE_ANALYTICS=true
ENABLE_CACHING=true
ENABLE_TRACING=true
ENABLE_METRICS=true

# =============================================================================
# Performance Configuration
# =============================================================================

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Caching
CACHE_TTL_SECONDS=300
CACHE_MAX_SIZE_MB=100

# Database Connection Pools
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT_MS=30000