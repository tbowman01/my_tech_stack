# Development Dockerfile for AI Inference with hot reload
FROM cgr.dev/chainguard/python:latest-dev

WORKDIR /app

# Copy requirements
COPY requirements.txt .

# Install dependencies
RUN pip install --no-cache-dir -r requirements.txt
RUN pip install --no-cache-dir watchdog uvicorn[standard]

# Copy source
COPY main.py .

# Switch to non-root user
USER 65532:65532

# Expose port
EXPOSE 8080

# Start with uvicorn reload for development
CMD ["python", "-m", "uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8080", "--reload"]